NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_wallet
JWT_SECRET=replace-with-very-long-secret-at-least-32-characters
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:4000

TELEGRAM_BOT_TOKEN=replace-with-wallet-bot-token
TELEGRAM_WEBAPP_URL=http://localhost:5173
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

TRAINING_JWT_SECRET=replace-with-another-very-long-secret
TRAINING_TELEGRAM_BOT_TOKEN=replace-with-training-bot-token
TRAINING_TELEGRAM_WEBAPP_URL=http://localhost:5176
TRAINING_TELEGRAM_WEBHOOK_URL=
TRAINING_TELEGRAM_WEBHOOK_SECRET=

BOT_MODE=polling
# Локально можно true для тестов без Telegram. В production код игнорирует true.
DEV_AUTH_BYPASS=true
