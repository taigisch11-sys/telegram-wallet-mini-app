NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_wallet
JWT_SECRET=replace-with-very-long-secret-at-least-32-characters
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:4000
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_WEBAPP_URL=http://localhost:5173
BOT_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
# Локально можно true для тестов без Telegram. В production код принудительно игнорирует true.
DEV_AUTH_BYPASS=true
