generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncomeStatus {
  planned
  delayed
  received_on_time
  received_late
  cancelled
}

enum PaymentStatus {
  planned
  overdue
  paid_on_time
  paid_late
  skipped
  cancelled
}

enum OperationKind {
  income
  expense
  transfer
  debt_repayment
  adjustment
  unallocated
}

enum PlannedOperationStatus {
  planned
  overdue
  done
  skipped
  cancelled
}

enum CategoryType {
  income
  expense
  transfer
  debt
}

model User {
  id                String             @id @default(cuid())
  telegramId        String             @unique
  username          String?
  firstName         String?
  createdAt         DateTime           @default(now())
  accounts          Account[]
  debts             Debt[]
  incomes           Income[]
  payments          Payment[]
  categories        Category[]
  operations        Operation[]
  plannedOperations PlannedOperation[]
  operationSeries   OperationSeries[]
  settings          Settings?
  snapshots         BalanceSnapshot[]
  history           History[]
}

model Category {
  id                String             @id @default(cuid())
  userId            String
  name              String
  type              CategoryType
  color             String             @default("#5b8cff")
  icon              String             @default("tag")
  isDefault         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes           Income[]
  payments          Payment[]
  operations        Operation[]
  plannedOperations PlannedOperation[]
  operationSeries   OperationSeries[]

  @@unique([userId, name, type])
  @@index([userId, type])
}

model Account {
  id        String   @id @default(cuid())
  userId    String
  name      String
  balance   Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Debt {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Income {
  id           String       @id @default(cuid())
  userId       String
  name         String
  amount       Decimal      @db.Decimal(14, 2)
  plannedDate  DateTime
  expectedDate DateTime?
  actualDate   DateTime?
  status       IncomeStatus
  note         String?
  categoryId   String?
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, plannedDate])
  @@index([categoryId])
}

model Payment {
  id           String        @id @default(cuid())
  userId       String
  name         String
  amount       Decimal       @db.Decimal(14, 2)
  plannedDate  DateTime
  expectedDate DateTime?
  actualDate   DateTime?
  status       PaymentStatus
  note         String?
  categoryId   String?
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, plannedDate])
  @@index([categoryId])
}

model OperationSeries {
  id                String             @id @default(cuid())
  userId            String
  name              String
  kind              OperationKind
  defaultAmount     Decimal            @db.Decimal(14, 2)
  finalAmount       Decimal?           @db.Decimal(14, 2)
  startDate         DateTime
  count             Int
  sourceAccountId   String?
  targetAccountId   String?
  targetDebtId      String?
  categoryId        String?
  createdAt         DateTime           @default(now())
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  plannedOperations PlannedOperation[]

  @@index([userId, createdAt])
  @@index([categoryId])
}

model PlannedOperation {
  id              String                 @id @default(cuid())
  userId          String
  kind            OperationKind
  name            String
  amount          Decimal                @db.Decimal(14, 2)
  plannedDate     DateTime
  expectedDate    DateTime?
  actualDate      DateTime?
  status          PlannedOperationStatus
  note            String?
  sourceAccountId String?
  targetAccountId String?
  targetDebtId    String?
  seriesId        String?
  categoryId      String?
  createdAt       DateTime               @default(now())
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series          OperationSeries?       @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  category        Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, plannedDate])
  @@index([seriesId])
  @@index([categoryId])
}

model Operation {
  id                 String           @id @default(cuid())
  userId             String
  kind               OperationKind
  name               String
  amount             Decimal          @db.Decimal(14, 2)
  operationDate      DateTime
  note               String?
  plannedOperationId String?
  seriesId           String?
  categoryId         String?
  createdAt          DateTime         @default(now())
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category           Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  entries            OperationEntry[]

  @@index([userId, operationDate])
  @@index([plannedOperationId])
  @@index([categoryId])
}

model OperationEntry {
  id          String    @id @default(cuid())
  operationId String
  targetType  String
  targetId    String
  amount      Decimal   @db.Decimal(14, 2)
  createdAt   DateTime  @default(now())
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([operationId])
  @@index([targetType, targetId])
}

model Settings {
  userId        String   @id
  currentMonth  String
  startBalance  Decimal  @db.Decimal(14, 2)
  editedBalance Decimal? @db.Decimal(14, 2)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BalanceSnapshot {
  id             String   @id @default(cuid())
  userId         String
  accountBalance Decimal  @db.Decimal(14, 2)
  debtBalance    Decimal  @db.Decimal(14, 2)
  netBalance     Decimal  @db.Decimal(14, 2)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model History {
  id        String   @id @default(cuid())
  userId    String
  type      String
  payload   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TelegramUpdate {
  id          String   @id @default(cuid())
  updateId    BigInt   @unique
  processedAt DateTime @default(now())
}

model TrainingUser {
  id                  String                       @id @default(cuid())
  telegramId          String                       @unique
  username            String?
  firstName           String?
  role                String                       @default("student")
  createdAt           DateTime                     @default(now())
  coachLinks          TrainingCoachStudent[]       @relation("TrainingCoach")
  studentLinks        TrainingCoachStudent[]       @relation("TrainingStudent")
  coachPlans          TrainingPlan[]               @relation("TrainingPlanCoach")
  studentPlans        TrainingPlan[]               @relation("TrainingPlanStudent")
  coachSessions       TrainingSession[]            @relation("TrainingSessionCoach")
  studentSessions     TrainingSession[]            @relation("TrainingSessionStudent")
  sentMessages        TrainingChatMessage[]        @relation("TrainingMessageSender")
  coachMessages       TrainingChatMessage[]        @relation("TrainingMessageCoach")
  studentMessages     TrainingChatMessage[]        @relation("TrainingMessageStudent")
  balanceTransactions TrainingBalanceTransaction[]

  @@index([role])
}

model TrainingCoachStudent {
  id         String       @id @default(cuid())
  coachId    String
  studentId  String
  status     String       @default("active")
  goal       String       @default("Персональное ведение")
  risk       String       @default("green")
  compliance Int          @default(100)
  joinedAt   DateTime     @default(now())
  coach      TrainingUser @relation("TrainingCoach", fields: [coachId], references: [id], onDelete: Cascade)
  student    TrainingUser @relation("TrainingStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([coachId, studentId])
  @@index([studentId])
}

model TrainingPlan {
  id        String            @id @default(cuid())
  coachId   String
  studentId String?
  title     String
  goal      String
  startDate DateTime
  weeks     Int               @default(4)
  status    String            @default("active")
  createdAt DateTime          @default(now())
  coach     TrainingUser      @relation("TrainingPlanCoach", fields: [coachId], references: [id], onDelete: Cascade)
  student   TrainingUser?     @relation("TrainingPlanStudent", fields: [studentId], references: [id], onDelete: SetNull)
  sessions  TrainingSession[]

  @@index([coachId, createdAt])
  @@index([studentId, startDate])
}

model TrainingSession {
  id            String             @id @default(cuid())
  planId        String?
  coachId       String
  studentId     String?
  title         String
  scheduledDate DateTime
  status        String             @default("planned")
  focus         String             @default("Сила")
  durationMin   Int                @default(45)
  intensity     Int                @default(6)
  createdAt     DateTime           @default(now())
  plan          TrainingPlan?      @relation(fields: [planId], references: [id], onDelete: Cascade)
  coach         TrainingUser       @relation("TrainingSessionCoach", fields: [coachId], references: [id], onDelete: Cascade)
  student       TrainingUser?      @relation("TrainingSessionStudent", fields: [studentId], references: [id], onDelete: SetNull)
  exercises     TrainingExercise[]
  logs          TrainingWorkoutLog[]

  @@index([coachId, scheduledDate])
  @@index([studentId, scheduledDate])
}

model TrainingExercise {
  id         String               @id @default(cuid())
  sessionId  String
  name       String
  sets       Int
  reps       String
  weight     String
  restSec    Int                  @default(90)
  notes      String               @default("")
  sortOrder  Int                  @default(0)
  actualSets Int                  @default(0)
  createdAt  DateTime             @default(now())
  session    TrainingSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  logs       TrainingWorkoutLog[]

  @@index([sessionId, sortOrder])
}

model TrainingWorkoutLog {
  id         String            @id @default(cuid())
  sessionId  String
  studentId  String
  exerciseId String?
  status     String            @default("done")
  actualSets Int               @default(0)
  feedback   String?
  createdAt  DateTime          @default(now())
  session    TrainingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise   TrainingExercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([studentId, createdAt])
}

model TrainingChatMessage {
  id        String       @id @default(cuid())
  coachId   String
  studentId String
  senderId  String
  body      String
  context   String?
  createdAt DateTime     @default(now())
  readAt    DateTime?
  coach     TrainingUser @relation("TrainingMessageCoach", fields: [coachId], references: [id], onDelete: Cascade)
  student   TrainingUser @relation("TrainingMessageStudent", fields: [studentId], references: [id], onDelete: Cascade)
  sender    TrainingUser @relation("TrainingMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([coachId, createdAt])
  @@index([studentId, createdAt])
}

model TrainingBalanceTransaction {
  id        String       @id @default(cuid())
  userId    String
  kind      String
  amount    Decimal      @db.Decimal(14, 2)
  status    String       @default("success")
  note      String
  createdAt DateTime     @default(now())
  user      TrainingUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TrainingTelegramUpdate {
  id          String   @id @default(cuid())
  updateId    BigInt   @unique
  processedAt DateTime @default(now())
}
