generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncomeStatus {
  planned
  delayed
  received_on_time
  received_late
  cancelled
}

enum PaymentStatus {
  planned
  overdue
  paid_on_time
  paid_late
  skipped
  cancelled
}

enum OperationKind {
  income
  expense
  transfer
  debt_repayment
  adjustment
  unallocated
}

enum PlannedOperationStatus {
  planned
  overdue
  done
  skipped
  cancelled
}

model User {
  id                String             @id @default(cuid())
  telegramId        String             @unique
  username          String?
  firstName         String?
  createdAt         DateTime           @default(now())
  accounts          Account[]
  debts             Debt[]
  incomes           Income[]
  payments          Payment[]
  operations        Operation[]
  plannedOperations PlannedOperation[]
  operationSeries   OperationSeries[]
  settings          Settings?
  snapshots         BalanceSnapshot[]
  history           History[]
}

model Account {
  id        String   @id @default(cuid())
  userId    String
  name      String
  balance   Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Debt {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Income {
  id           String       @id @default(cuid())
  userId       String
  name         String
  amount       Decimal      @db.Decimal(14, 2)
  plannedDate  DateTime
  expectedDate DateTime?
  actualDate   DateTime?
  status       IncomeStatus
  note         String?
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, plannedDate])
}

model Payment {
  id           String        @id @default(cuid())
  userId       String
  name         String
  amount       Decimal       @db.Decimal(14, 2)
  plannedDate  DateTime
  expectedDate DateTime?
  actualDate   DateTime?
  status       PaymentStatus
  note         String?
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, plannedDate])
}

model OperationSeries {
  id                String             @id @default(cuid())
  userId            String
  name              String
  kind              OperationKind
  defaultAmount     Decimal            @db.Decimal(14, 2)
  finalAmount       Decimal?           @db.Decimal(14, 2)
  startDate         DateTime
  count             Int
  sourceAccountId   String?
  targetAccountId   String?
  targetDebtId      String?
  createdAt         DateTime           @default(now())
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedOperations PlannedOperation[]

  @@index([userId, createdAt])
}

model PlannedOperation {
  id              String                 @id @default(cuid())
  userId          String
  kind            OperationKind
  name            String
  amount          Decimal                @db.Decimal(14, 2)
  plannedDate     DateTime
  expectedDate    DateTime?
  actualDate      DateTime?
  status          PlannedOperationStatus
  note            String?
  sourceAccountId String?
  targetAccountId String?
  targetDebtId    String?
  seriesId        String?
  createdAt       DateTime               @default(now())
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  series          OperationSeries?       @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([userId, plannedDate])
  @@index([seriesId])
}

model Operation {
  id                 String           @id @default(cuid())
  userId             String
  kind               OperationKind
  name               String
  amount             Decimal          @db.Decimal(14, 2)
  operationDate      DateTime
  note               String?
  plannedOperationId String?
  seriesId           String?
  createdAt          DateTime         @default(now())
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries            OperationEntry[]

  @@index([userId, operationDate])
  @@index([plannedOperationId])
}

model OperationEntry {
  id          String    @id @default(cuid())
  operationId String
  targetType  String
  targetId    String
  amount      Decimal   @db.Decimal(14, 2)
  createdAt   DateTime  @default(now())
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@index([operationId])
  @@index([targetType, targetId])
}

model Settings {
  userId        String   @id
  currentMonth  String
  startBalance  Decimal  @db.Decimal(14, 2)
  editedBalance Decimal? @db.Decimal(14, 2)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BalanceSnapshot {
  id             String   @id @default(cuid())
  userId         String
  accountBalance Decimal  @db.Decimal(14, 2)
  debtBalance    Decimal  @db.Decimal(14, 2)
  netBalance     Decimal  @db.Decimal(14, 2)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model History {
  id        String   @id @default(cuid())
  userId    String
  type      String
  payload   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TelegramUpdate {
  id          String   @id @default(cuid())
  updateId    BigInt   @unique
  processedAt DateTime @default(now())
}
