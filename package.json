{
  "name": "telegram-wallet-mini-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace apps/frontend",
    "dev:backend": "npm run dev --workspace apps/backend",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "local:db:start": "powershell -ExecutionPolicy Bypass -File scripts/local-db-start.ps1",
    "local:db:stop": "powershell -ExecutionPolicy Bypass -File scripts/local-db-stop.ps1",
    "local:db:reset": "powershell -ExecutionPolicy Bypass -File scripts/local-db-reset.ps1",
    "deploy:worker": "npm run deploy --workspace @wallet/worker",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
